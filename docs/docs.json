{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "docs",
  "colors": {
    "primary": "#000000",
    "light": "#FFFF00",
    "dark": "#000000"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "guides/vision",
              "guides/libraries",
              "guides/setup"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "guides/fundamentals"
            ]
          }
        ]
      },
      {
        "tab": "Server",
        "groups": [
          {
            "group": "Typescript",
            "pages": [
              "languages/server/typescript/getting-started"
            ]
          }
        ]
      },
      {
        "tab": "Client",
        "groups": [
          {
            "group": "React",
            "pages": [
              "languages/client/react/getting-started"
            ]
          }
        ]
      },
      {
        "tab": "Frameworks",
        "groups": [
          {
            "group": "Typescript",
            "pages": [
              "frameworks/nestjs/index",
              "frameworks/encore/index"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
